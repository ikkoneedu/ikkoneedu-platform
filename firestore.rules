rules_version = '2';

// ikkoneedu — Firestore Security Rules
//
// Mimari:
//   users/{uid}                                  → kök kullanıcı profilleri (MVP)
//   tenants/{tenantId}/...                        → çoklu kiracılık verileri
//   tenants/{tenantId}/demoRequests              → HALKA AÇIK form (anonim create)
//   tenants/{tenantId}/scholarshipApplications   → HALKA AÇIK form (anonim create)
//   tenants/{tenantId}/leads                      → İÇ CRM (yalnızca tenant üyesi)
//   platform/...                                  → yalnızca SUPER_ADMIN
//   connectionTests/...                           → firebase-check.mjs (geçici)
//
// Yetki kaynağı: kullanıcının users/{uid} profilindeki role + tenantId.
// (Custom claims'e geçilene kadar Firestore profili kullanılır.)

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Yardımcı fonksiyonlar --------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return hasProfile() ? myProfile().role : '';
    }

    function myTenant() {
      return hasProfile() ? myProfile().tenantId : '';
    }

    function isActiveUser() {
      return hasProfile() && myProfile().status == 'ACTIVE';
    }

    // Custom claim'de rol (atanmışsa). Profil okumadan hızlı kontrol sağlar.
    function tokenRole() {
      return isSignedIn() && ('role' in request.auth.token)
        ? request.auth.token.role : '';
    }

    function isSuperAdmin() {
      // Önce custom claim; yoksa Firestore profili (geriye dönük uyumlu).
      return tokenRole() == 'SUPER_ADMIN'
        || (isActiveUser() && myRole() == 'SUPER_ADMIN');
    }

    // Veli, verilen öğrenciye bağlı mı? (linkedStudentIds içinde mi)
    function isLinkedParent(studentUid) {
      return hasProfile()
        && ('linkedStudentIds' in myProfile())
        && myProfile().linkedStudentIds.hasAny([studentUid]);
    }

    // Okul personeli: tenant verisine yazabilen kadro.
    function isStaff() {
      return isActiveUser()
        && (myRole() == 'TEACHER' || myRole() == 'PRINCIPAL'
            || myRole() == 'VICE_PRINCIPAL' || myRole() == 'COORDINATOR'
            || myRole() == 'SCHOOL_ADMIN' || myRole() == 'FOUNDER'
            || myRole() == 'SUPER_ADMIN');
    }

    // Okul yönetimi: personel hesabı oluşturabilen / kullanıcı yönetebilen kadro.
    function isSchoolManager() {
      return isActiveUser()
        && (myRole() == 'SCHOOL_ADMIN' || myRole() == 'FOUNDER'
            || myRole() == 'PRINCIPAL' || myRole() == 'SUPER_ADMIN');
    }

    // Okul kayıt yönetimi (öğrenci/veli/öğretmen/sınıf yazma yetkisi):
    // yönetim + koordinatör + müdür yardımcısı (öğretmen HARİÇ).
    function canManageRecords() {
      return isActiveUser()
        && (myRole() == 'SCHOOL_ADMIN' || myRole() == 'FOUNDER'
            || myRole() == 'PRINCIPAL' || myRole() == 'VICE_PRINCIPAL'
            || myRole() == 'COORDINATOR' || myRole() == 'SUPER_ADMIN');
    }

    // Üst yönetim rolleri — yetki yükseltme engellerinde kullanılır.
    function isManagementRole(role) {
      return role == 'SUPER_ADMIN' || role == 'FOUNDER' || role == 'SCHOOL_ADMIN';
    }

    // Kullanıcı bu tenant'a mı ait? (SUPER_ADMIN tüm tenant'lara erişir.)
    function isTenantMember(tenantId) {
      return isActiveUser() && (myTenant() == tenantId || isSuperAdmin());
    }

    // Okul askıda/iptal DEĞİL mi? Gerçek tenant belgesi yoksa (mock/eski) muaftır
    // (geriye dönük uyumlu). Hem eski büyük harf ('SUSPENDED') hem yeni enum
    // ('suspended'/'cancelled') engellenir.
    function tenantNotSuspended(tenantId) {
      return !exists(/databases/$(database)/documents/tenants/$(tenantId))
        || !(get(/databases/$(database)/documents/tenants/$(tenantId)).data.status
             in ['SUSPENDED', 'suspended', 'cancelled']);
    }

    // ---- Halka açık form doğrulayıcıları ----------------------------------
    // `allow create: if true` yerine alan/boyut/değer doğrulaması yapılır.
    function isShortString(v, maxLen) {
      return v is string && v.size() <= maxLen;
    }
    function isFilledString(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }
    // createdAt istemciden TRUST edilmez: serverTimestamp() == request.time olmalı.
    function createdAtIsServer(d) {
      return d.createdAt == request.time;
    }

    // Okula özel aday/iletişim talebi (tenants/{id}/demoRequests).
    function validSchoolInquiry(tenantId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['schoolName','institution','fullName','phone','email','grade','message','type','status','createdAt'])
        && d.keys().hasAll(['fullName','phone','email','type','status','createdAt'])
        && d.type == 'school_inquiry'
        && d.status == 'new'
        && isFilledString(d.fullName, 120)
        && isFilledString(d.phone, 40)
        && isFilledString(d.email, 200)
        && (!('schoolName' in d) || isShortString(d.schoolName, 200))
        && (!('institution' in d) || isShortString(d.institution, 200))
        && (!('grade' in d) || isShortString(d.grade, 60))
        && (!('message' in d) || isShortString(d.message, 2000))
        && createdAtIsServer(d);
    }

    // Platform düzeyi SaaS demo talebi (platformDemoRequests).
    function validPlatformDemo() {
      let d = request.resource.data;
      return d.keys().hasOnly(['institution','fullName','role','phone','email','city','institutionType','studentCount','message','type','status','createdAt'])
        && d.keys().hasAll(['institution','fullName','phone','email','type','status','createdAt'])
        && d.type == 'demo_request'
        && d.status == 'new'
        && isFilledString(d.institution, 200)
        && isFilledString(d.fullName, 120)
        && isFilledString(d.phone, 40)
        && isFilledString(d.email, 200)
        && (!('role' in d) || isShortString(d.role, 80))
        && (!('city' in d) || isShortString(d.city, 80))
        && (!('institutionType' in d) || isShortString(d.institutionType, 80))
        && (!('studentCount' in d) || isShortString(d.studentCount, 40))
        && (!('message' in d) || isShortString(d.message, 2000))
        && createdAtIsServer(d);
    }

    // Bursluluk başvurusu (tenants/{id}/scholarshipApplications).
    // tenantId alanı belge yolundaki tenant ile AYNI olmalı (tutarlılık).
    function validScholarshipApplication(tenantId) {
      let d = request.resource.data;
      return d.keys().hasOnly(['tenantId','applicationNo','studentName','studentTc','birthDate','parentName','parentPhone','parentEmail','district','address','type','status','createdAt'])
        && d.keys().hasAll(['tenantId','applicationNo','studentName','parentName','parentPhone','parentEmail','type','status','createdAt'])
        && d.type == 'scholarship_application'
        && d.status == 'received'
        && d.tenantId == tenantId
        && isFilledString(d.applicationNo, 60)
        && isFilledString(d.studentName, 120)
        && isFilledString(d.parentName, 120)
        && isFilledString(d.parentPhone, 40)
        && isFilledString(d.parentEmail, 200)
        && (!('studentTc' in d) || isShortString(d.studentTc, 20))
        && (!('birthDate' in d) || isShortString(d.birthDate, 20))
        && (!('district' in d) || isShortString(d.district, 80))
        && (!('address' in d) || isShortString(d.address, 300))
        && createdAtIsServer(d);
    }

    // ---- Kök kullanıcı profilleri -----------------------------------------
    match /users/{uid} {
      // Kullanıcı kendi profilini okur; SUPER_ADMIN tümünü okur;
      // personel kendi tenant'ındaki kullanıcıları okur (listeleme).
      allow read: if isSelf(uid)
        || isSuperAdmin()
        || (isStaff() && resource.data.tenantId == myTenant());

      // Halk (genel kullanıcı) açık kaydı: kullanıcı YALNIZCA kendi belgesini
      // ve YALNIZCA PUBLIC rol + public tenant ile oluşturabilir
      // (yetki yükseltmeyi önler). Diğer tüm profilleri SUPER_ADMIN oluşturur.
      allow create: if isSuperAdmin()
        || (
          // Halk açık kaydı: yalnızca kendi belgesi, PUBLIC rol + public tenant.
          isSelf(uid)
          && request.resource.data.role == 'PUBLIC'
          && request.resource.data.tenantId == 'public'
          && request.resource.data.status == 'ACTIVE'
        )
        || (
          // Personel, kendi tenant'ında öğrenci/veli profili oluşturabilir.
          isStaff()
          && (request.resource.data.role == 'STUDENT'
              || request.resource.data.role == 'PARENT')
          && request.resource.data.tenantId == myTenant()
        )
        || (
          // Okul yönetimi (kurucu/okul yöneticisi) kendi tenant'ında personel
          // hesabı oluşturabilir: müdür, müdür yrd., koordinatör, öğretmen, PR.
          isSchoolManager()
          && (request.resource.data.role == 'TEACHER'
              || request.resource.data.role == 'PRINCIPAL'
              || request.resource.data.role == 'VICE_PRINCIPAL'
              || request.resource.data.role == 'COORDINATOR'
              || request.resource.data.role == 'PR')
          && request.resource.data.tenantId == myTenant()
        );

      // Güncelleme: SUPER_ADMIN her şeyi; kullanıcı kendi profilini güncelleyebilir
      // ANCAK rol/tenant/status'ü değiştiremez.
      allow update: if isSuperAdmin()
        || (
          isSelf(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.status == resource.data.status
        )
        || (
          // Okul yönetimi (kurucu/okul yön./müdür) kendi tenant'ındaki bir
          // kullanıcının durum/rolünü güncelleyebilir. Yetki yükseltme engeli:
          // hedefin mevcut rolü ve atanacak yeni rol ÜST YÖNETİM olamaz; tenant
          // değiştirilemez (başka okula taşıma yok).
          isSchoolManager()
          && resource.data.tenantId == myTenant()
          && request.resource.data.tenantId == resource.data.tenantId
          && !isManagementRole(resource.data.role)
          && !isManagementRole(request.resource.data.role)
        );
      allow delete: if isSuperAdmin();
    }

    // ---- Okul (tenant) belgesi --------------------------------------------
    // Not: `tenants/{tenantId}/{document=**}` üst belgenin KENDİSİNİ kapsamaz,
    // bu yüzden okul belgesi için ayrı kural gerekir.
    // Okuma: HERKES (halka açık okul dizini + public okul sayfaları). Belge
    // yalnızca okul adı/şehir/durum gibi tanıtım bilgisi taşır; gizli değildir.
    // Oluşturma/güncelleme/silme: yalnızca SUPER_ADMIN.
    match /tenants/{tenantId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    // ---- Okul profilleri (kök `schools`) ----------------------------------
    // Okulun iletişim/kimlik profili (tenant aboneliğinden ayrı).
    // Okuma: ilgili tenant üyesi veya SUPER_ADMIN.
    // Oluşturma/silme: yalnızca SUPER_ADMIN (onboarding).
    // Güncelleme: SUPER_ADMIN veya kendi okulunun yöneticisi.
    match /schools/{schoolId} {
      allow read: if isSuperAdmin()
        || (isActiveUser() && resource.data.tenantId == myTenant());
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (isSchoolManager() && resource.data.tenantId == myTenant()
            && request.resource.data.tenantId == resource.data.tenantId);
    }

    // ---- Halka açık form gönderimleri (anonim oluşturma) ------------------
    // Okula özel aday/iletişim talepleri — herkes DOĞRULAMALI gönderebilir,
    // yalnızca tenant üyesi okur. (Platform SaaS demoları kökte: aşağıya bkz.)
    match /tenants/{tenantId}/demoRequests/{docId} {
      allow create: if validSchoolInquiry(tenantId);
      allow read, update, delete: if isTenantMember(tenantId);
    }

    // Bursluluk başvuruları — herkes DOĞRULAMALI gönderebilir, tenant üyesi okur.
    // applicationNo belge kimliğidir; create-only kuralı üzerine yazmayı önler
    // (mevcut belgeye yazım update sayılır ve yalnızca tenant üyesine açıktır).
    match /tenants/{tenantId}/scholarshipApplications/{docId} {
      allow create: if validScholarshipApplication(tenantId);
      allow read, update, delete: if isTenantMember(tenantId);
    }

    // ---- Platform düzeyi SaaS demo talepleri (kök) ------------------------
    // Bir okula ait değildir. Herkes DOĞRULAMALI oluşturabilir; yalnızca
    // SUPER_ADMIN okur/günceller/siler.
    match /platformDemoRequests/{docId} {
      allow create: if validPlatformDemo();
      allow read, update, delete: if isSuperAdmin();
    }

    // ---- Platform düzeyi SaaS satış lead'leri (kök) ----------------------
    // Okul henüz tenant değildir; ilk satış lead'i burada tutulur. Yalnızca
    // SUPER_ADMIN okur/yazar (demo talebinden "Lead'e Çevir" ile oluşturulur).
    match /platformLeads/{leadId} {
      allow read, write: if isSuperAdmin();
    }

    // Yayımlanmış bursluluk SONUÇLARI — veli/aday başvuru numarasıyla sorgular.
    // Okuma HERKESE açıktır (belge id = başvuru no, erişim anahtarıdır; içerik
    // hassas değildir: ad, puan, burs oranı, salon). Yazma yalnızca personel.
    match /tenants/{tenantId}/scholarshipResults/{appNo} {
      allow read: if true;
      allow write: if isStaff() && myTenant() == tenantId
        && tenantNotSuspended(tenantId);
    }

    // CRM lead — iç kullanım; yalnızca tenant üyesi oluşturur/okur.
    match /tenants/{tenantId}/leads/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }

    // CRM randevuları — lead'ler gibi; PR/SALES dahil tenant üyesi yönetir.
    // (Genel tenant kuralı yazımı isStaff ister; PR/SALES isStaff değildir.)
    match /tenants/{tenantId}/appointments/{docId} {
      allow read, write: if isTenantMember(tenantId);
    }

    // ---- Mesajlar (gizli — yalnızca gönderen/alıcı) -----------------------
    // ÖNEMLİ: Genel `{document=**}` kuralı bu yolu OKUMA için HARİÇ tutar
    // (aşağıda `document[0] != 'messages'`), böylece tenant üyesi bile
    // başkalarının mesajını okuyamaz; yalnızca bu kurallar geçerlidir.
    match /tenants/{tenantId}/messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid
        || request.auth.uid in resource.data.recipientIds
      );
      // Oluşturma: aktif tenant üyesi; senderId kendisi; tenantId yol ile aynı.
      allow create: if isActiveUser() && myTenant() == tenantId
        && tenantNotSuspended(tenantId)
        && request.resource.data.tenantId == tenantId
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'sent';
      // Güncelleme: gönderen (durum: archived/deleted) veya alıcı (readBy).
      allow update: if isSignedIn() && (
        resource.data.senderId == request.auth.uid
        || request.auth.uid in resource.data.recipientIds
      );
      // Gerçek silme yok (soft delete = status).
      allow delete: if false;
    }

    // ---- Bildirimler (gizlilik: kişisel olanlar yalnız sahibi/personel) ----
    // Genel `{document=**}` kuralı OKUMA için bunları HARİÇ tutar; yalnızca bu
    // kural geçerlidir. Kişisel bildirim (userId alanı) sahibi veya personel
    // tarafından okunur; yayın bildirimi (userId yok) tenant üyesine açıktır.
    match /tenants/{tenantId}/notifications/{notificationId} {
      allow read: if isTenantMember(tenantId) && (
        isStaff()
        || !('userId' in resource.data)
        || resource.data.userId == request.auth.uid
      );
      // Oluşturma: aktif tenant üyesi (mesaj fan-out'u veli/öğrenci tarafından
      // da tetiklenebilir). Personel duyuru fan-out'u da buradan geçer.
      allow create: if isTenantMember(tenantId) && tenantNotSuspended(tenantId);
      // Güncelleme: yalnızca sahibi (okundu işareti) — userId değiştirilemez.
      allow update: if isTenantMember(tenantId)
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    // ---- Okul kayıt omurgası (öğrenci/veli/öğretmen) ----------------------
    // Genel `{document=**}` kuralı bunları OKUMA ve YAZMA için HARİÇ tutar;
    // yalnızca aşağıdaki kurallar geçerlidir (gizlilik + yetki).
    //
    // Öğrenciler: yönetim/öğretmen (personel) okur; kendi kaydı (id==uid) veya
    // veli (parentIds) ileri uyum için. Yazma: kayıt yönetimi. Soft delete.
    match /tenants/{tenantId}/students/{studentId} {
      allow read: if isSuperAdmin()
        || (isTenantMember(tenantId) && isStaff())
        || isSelf(studentId)
        || (hasProfile() && 'parentIds' in resource.data
            && request.auth.uid in resource.data.parentIds);
      allow create: if isSuperAdmin()
        || (canManageRecords() && myTenant() == tenantId
            && tenantNotSuspended(tenantId)
            && request.resource.data.tenantId == tenantId);
      allow update: if isSuperAdmin()
        || (canManageRecords() && myTenant() == tenantId
            && tenantNotSuspended(tenantId));
      allow delete: if false; // soft delete (status) — gerçek silme yok
    }

    // Veliler: yönetim/öğretmen okur. Yazma: kayıt yönetimi. Soft delete.
    match /tenants/{tenantId}/parents/{parentId} {
      allow read: if isSuperAdmin()
        || (isTenantMember(tenantId) && isStaff())
        || isSelf(parentId);
      allow create: if isSuperAdmin()
        || (canManageRecords() && myTenant() == tenantId
            && tenantNotSuspended(tenantId)
            && request.resource.data.tenantId == tenantId);
      allow update: if isSuperAdmin()
        || (canManageRecords() && myTenant() == tenantId
            && tenantNotSuspended(tenantId));
      allow delete: if false;
    }

    // Öğretmen kayıtları (okul profili/kadro): yönetim/öğretmen okur. Yazma:
    // kayıt yönetimi. Soft delete.
    match /tenants/{tenantId}/teachers/{teacherId} {
      allow read: if isSuperAdmin()
        || (isTenantMember(tenantId) && isStaff())
        || isSelf(teacherId);
      allow create: if isSuperAdmin()
        || (canManageRecords() && myTenant() == tenantId
            && tenantNotSuspended(tenantId)
            && request.resource.data.tenantId == tenantId);
      allow update: if isSuperAdmin()
        || (canManageRecords() && myTenant() == tenantId
            && tenantNotSuspended(tenantId));
      allow delete: if false;
    }

    // ---- Diğer tüm tenant verileri ----------------------------------------
    // Öğrenci, öğretmen, veli, duyuru, mesaj, ayar, auditLog vb.
    // Okuma: tenant üyesi (öğrenci/veli dahil). Yazma: yalnızca personel
    // (öğrenci/veli tenant verisine yazamaz — ör. duyuru oluşturamaz).
    match /tenants/{tenantId}/{document=**} {
      // Mesaj ve bildirimler OKUMA için HARİÇ (gizlilik): bunlar yalnızca
      // yukarıdaki özel kurallarla okunur; tenant üyesi geneli göremez.
      // `document[0]` ilk alt koleksiyon adıdır (ör. 'messages').
      allow read: if isTenantMember(tenantId)
        && document[0] != 'messages'
        && document[0] != 'notifications'
        && document[0] != 'students'
        && document[0] != 'parents'
        && document[0] != 'teachers';
      // Askıdaki okulun personeli veri yazamaz (süper admin ayrı kurallarla erişir).
      // Mesaj/öğrenci/veli/öğretmen yazımı özel kurallarla yönetilir (hariç).
      // (Sınıflar bu kuralda kalır: öğretmen kendi ders sınıfını oluşturabilir.)
      allow write: if isStaff() && myTenant() == tenantId
        && tenantNotSuspended(tenantId)
        && document[0] != 'messages'
        && document[0] != 'students'
        && document[0] != 'parents'
        && document[0] != 'teachers';
    }

    // ---- Global CRM (collection group) — yalnızca SUPER_ADMIN -------------
    // Süper admin TÜM okulların CRM verisini tek sorguda okur. Bu kurallar
    // yalnızca collection group sorgularına izin verir; tenant izolasyonunu
    // bozmaz (tenant üyeleri yine yalnızca kendi alt koleksiyonlarını okur).
    match /{path=**}/leads/{leadId} {
      allow read: if isSuperAdmin();
    }
    match /{path=**}/scholarshipApplications/{appId} {
      allow read: if isSuperAdmin();
    }
    match /{path=**}/demoRequests/{reqId} {
      allow read: if isSuperAdmin();
    }

    // ---- Platform geneli yapılandırma -------------------------------------
    match /platform/{document=**} {
      allow read: if isActiveUser();
      allow write: if isSuperAdmin();
    }

    // ---- Platform denetim kayıtları (yalnızca SUPER_ADMIN) ----------------
    // Kök koleksiyon; değiştirilemez (append-only). Okuma/oluşturma süper admin.
    match /platformAuditLogs/{docId} {
      allow read, create: if isSuperAdmin();
      allow update, delete: if false;
    }

    // ---- Öğrenci kayıtları / notlar (kök; gizli) --------------------------
    // Okuma: öğrencinin kendisi, bağlı velisi, aynı tenant personeli.
    // Yazma: yalnızca aynı tenant personeli.
    match /studentRecords/{studentUid} {
      allow read: if isSelf(studentUid)
        || (isStaff() && resource.data.tenantId == myTenant())
        || isLinkedParent(studentUid);
      allow write: if isStaff()
        && request.resource.data.tenantId == myTenant();
    }

    // ---- Birebir mesajlar (kök; katılımcı bazlı erişim) -------------------
    // Yalnızca participants dizisindeki kullanıcılar okur; gönderen kendi
    // adına yazar. Güncelleme/silme kapalı.
    match /directMessages/{msgId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
        && hasProfile()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- Bağlantı testi (firebase-check.mjs) ------------------------------
    // ÜRETİM: yazma kapalı. `firebase-check.mjs` bu durumda "permission-denied"
    // alır ve bunu "bağlantı VAR, kurallar sıkı" olarak BAŞARI sayar (exit 0);
    // dolayısıyla bağlantı testi yine çalışır, veri sızıntısı/şişmesi olmaz.
    match /connectionTests/{docId} {
      allow create, read, update, delete: if false;
    }

    // ---- Varsayılan: her şey kapalı ---------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
