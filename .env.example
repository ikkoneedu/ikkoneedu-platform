# ikkoneedu — Ortam Değişkenleri (örnek)
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# Gerçek anahtarları asla depoya commit etmeyin.

# Uygulama
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_URL=

# Firebase (istemci — Firebase Console > Proje Ayarları > Web uygulaması)
# Bu değerler istemciye gönderilir; Firebase için bu normaldir.
# Erişim güvenliği Firestore Security Rules ile sağlanır.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────────────
# SUNUCU TARAFI GİZLİ ANAHTARLAR (NEXT_PUBLIC_ ÖNEKİ YOK — İSTEMCİYE SIZMAZ)
# Bu değişkenler yalnızca server component / route handler / middleware
# içinde okunmalıdır. ASLA NEXT_PUBLIC_ öneki eklemeyin; aksi halde tarayıcıya
# gönderilirler. Bu sürümde kullanılmazlar; ileride eklenecektir.
# ─────────────────────────────────────────────────────────────────────────

# Firebase Admin SDK (sunucu) — service account (ileride; auth doğrulama için)
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# Yapay Zeka sağlayıcıları (yalnızca sunucu — istemciye sızdırmayın).
# Tanımlıysa GERÇEK AI (lib/ai/registry.ts ajan dağılımı); tanımsızsa demo.
# En az birini ekleyin; her ajan tercih sırasına göre anahtarı olanı kullanır.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Personel giriş-çıkış QR imza sırrı (sunucu) — ≥16 karakter güçlü rastgele.
ATTENDANCE_QR_SECRET=

# E-posta gönderimi (Resend) — giriş doğrulama kodu (OTP) e-postaları için.
# Tanımsızsa gerçek e-posta gönderilmez, kod konsola loglanır (mock/dev).
RESEND_API_KEY=
# Gönderen adresi (opsiyonel) — Resend'de doğrulanmış bir alan adı gerekir.
# Tanımsızsa Resend'in test adresi kullanılır (yalnız geliştirme için yeterli).
RESEND_FROM_EMAIL=

# Vercel Cron koruması (sunucu) — /api/cron/* yalnız bu Bearer ile çalışır.
CRON_SECRET=

# Firebase Admin (alternatif): tüm service account JSON'u TEK env olarak.
# Tanımlıysa FIREBASE_ADMIN_* üçlüsü yerine bu kullanılır (Vercel'de pratik).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
