rules_version = '2';

// Firebase Storage güvenlik kuralları.
// Personel kimlik kartı fotoğrafları: herkes OKUR (karta gömülü görsel),
// kullanıcı YALNIZCA kendi klasörüne yazar/siler. Diğer her şey kapalı.
service firebase.storage {
  match /b/{bucket}/o {
    match /staffPhotos/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        // En fazla 5 MB ve yalnızca görsel.
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Varsayılan: kapalı.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
