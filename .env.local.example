# ikkoneedu — Yerel Ortam Değişkenleri (örnek)
#
# Bu dosyayı `.env.local` olarak kopyalayın ve gerçek değerleri doldurun.
# `.env.local` dosyası .gitignore içindedir ve ASLA commit edilmez.
#
# Değerler boş bırakılırsa uygulama "Mock Mod" çalışır:
# formlar Firestore'a yazmaz, kullanıcıya yine de başarı mesajı gösterilir.

# Uygulama
# NEXT_PUBLIC_APP_URL canonical/SEO (sitemap, robots, og:url) için kullanılır.
NEXT_PUBLIC_APP_NAME=ikkoneedu
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase (istemci) — Firebase Console > Proje Ayarları > Web uygulaması
# NEXT_PUBLIC_ öneki istemciye gönderilir; Firebase web SDK için normaldir.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── SUNUCU TARAFI GİZLİ ANAHTARLAR (NEXT_PUBLIC_ YOK — İSTEMCİYE SIZMAZ) ───
# Firebase Admin SDK (custom claims + sunucu doğrulama).
# Firebase Console > Project Settings > Service accounts > Generate new private key.
# PRIVATE_KEY'i tek satırda, \n kaçışlı ve çift tırnak içinde yapıştırın.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Yapay Zeka sağlayıcıları (yalnızca sunucu — bu sürümde kullanılmaz)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
